SELECT UTF8(payload) FROM events WHERE devicetype=12 AND ((("Event ID"=4624 OR "EventID"=4624 OR "qidEventId"=4624) AND "SubjectUserSid"='S-1-0-0' AND ("Logon Type"=3 OR "Login Type"=3 OR "MSLogonType"=3) AND "LogonProcessName"='NtLmSsp' AND "KeyLength"=0) OR (("Event ID"=4624 OR "EventID"=4624 OR "qidEventId"=4624) AND ("Logon Type"=9 OR "Login Type"=9 OR "MSLogonType"=9) AND "LogonProcessName"='seclogo')) AND  NOT (("Target Username"='ANONYMOUS LOGON' OR "User"='ANONYMOUS LOGON' OR "userName"='ANONYMOUS LOGON' OR "Target User Name"='ANONYMOUS LOGON'))
