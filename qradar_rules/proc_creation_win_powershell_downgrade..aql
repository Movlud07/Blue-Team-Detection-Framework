SELECT UTF8(payload) FROM events WHERE devicetype=12 AND category=8110 AND (("Process Path" ILIKE '%\powershell.exe' OR "Process Name" ILIKE '%\powershell.exe' OR "DGApplication" ILIKE '%\powershell.exe' OR "ProcessName" ILIKE '%\powershell.exe') AND (("Command" ILIKE '% -version 2 %' OR "Command" ILIKE '% -versio 2 %' OR "Command" ILIKE '% -versi 2 %' OR "Command" ILIKE '% -vers 2 %' OR "Command" ILIKE '% -ver 2 %' OR "Command" ILIKE '% -ve 2 %' OR "Command" ILIKE '% -v 2 %') OR ("Encoded Argument" ILIKE '% -version 2 %' OR "Encoded Argument" ILIKE '% -versio 2 %' OR "Encoded Argument" ILIKE '% -versi 2 %' OR "Encoded Argument" ILIKE '% -vers 2 %' OR "Encoded Argument" ILIKE '% -ver 2 %' OR "Encoded Argument" ILIKE '% -ve 2 %' OR "Encoded Argument" ILIKE '% -v 2 %') OR ("Command Arguments" ILIKE '% -version 2 %' OR "Command Arguments" ILIKE '% -versio 2 %' OR "Command Arguments" ILIKE '% -versi 2 %' OR "Command Arguments" ILIKE '% -vers 2 %' OR "Command Arguments" ILIKE '% -ver 2 %' OR "Command Arguments" ILIKE '% -ve 2 %' OR "Command Arguments" ILIKE '% -v 2 %')))

