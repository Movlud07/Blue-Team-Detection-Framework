SELECT UTF8(payload) FROM events WHERE devicetype=12 AND ((("Event ID"=4720 OR "EventID"=4720 OR "qidEventId"=4720) AND "SamAccountName" ILIKE '%$%') OR (("Event ID"=4781 OR "EventID"=4781 OR "qidEventId"=4781) AND "NewTargetUserName" ILIKE '%$%')) AND  NOT ((("Event ID"=4720 OR "EventID"=4720 OR "qidEventId"=4720) AND ("Target Username"='HomeGroupUser$' OR "User"='HomeGroupUser$' OR "userName"='HomeGroupUser$' OR "Target User Name"='HomeGroupUser$')))
