SELECT UTF8(payload) FROM events WHERE devicetype=12 AND category=8110 AND ("Command" ILIKE '%-NoP -NoL -sta -NonI -W Hidden -Exec Bypass -Enc%' OR "Encoded Argument" ILIKE '%-NoP -NoL -sta -NonI -W Hidden -Exec Bypass -Enc%' OR "Command Arguments" ILIKE '%-NoP -NoL -sta -NonI -W Hidden -Exec Bypass -Enc%')

