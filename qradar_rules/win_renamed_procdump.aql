SELECT UTF8(payload) FROM events WHERE devicetype=12 AND category=8110 AND ("OriginalFileName"='procdump' OR ((("Command" ILIKE '% -ma %' OR "Encoded Argument" ILIKE '% -ma %' OR "Command Arguments" ILIKE '% -ma %') OR ("Command" ILIKE '% -mp %' OR "Encoded Argument" ILIKE '% -mp %' OR "Command Arguments" ILIKE '% -mp %')) AND ("Command" ILIKE '% /accepteula%' OR "Encoded Argument" ILIKE '% /accepteula%' OR "Command Arguments" ILIKE '% /accepteula%'))) AND  NOT ((("Process Path" ILIKE '%\procdump.exe' OR "Process Path" ILIKE '%\procdump64.exe') OR ("Process Name" ILIKE '%\procdump.exe' OR "Process Name" ILIKE '%\procdump64.exe') OR ("DGApplication" ILIKE '%\procdump.exe' OR "DGApplication" ILIKE '%\procdump64.exe') OR ("ProcessName" ILIKE '%\procdump.exe' OR "ProcessName" ILIKE '%\procdump64.exe')))
