SELECT UTF8(payload) FROM events WHERE devicetype=12 AND category=8110 AND ("Process Path" ILIKE '%\whoami.exe' OR "Process Name" ILIKE '%\whoami.exe' OR "DGApplication" ILIKE '%\whoami.exe' OR "ProcessName" ILIKE '%\whoami.exe')

